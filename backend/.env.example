# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# CORS Settings
# CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Whisper Configuration
WHISPER_MODEL=large-v2
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Training Defaults
DEFAULT_EPOCHS=15
DEFAULT_BATCH_SIZE=2
DEFAULT_LEARNING_RATE=5e-6

# Audio Processing
SAMPLE_RATE=22050
MIN_TOTAL_AUDIO_DURATION=600.0
MAX_UPLOAD_SIZE=524288000

# Paths (optional - defaults will be used if not set)
# BASE_DIR=/path/to/backend
# DATA_DIR=/path/to/data
# MODELS_DIR=/path/to/trained_models
